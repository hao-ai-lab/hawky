# Hawky web frontend — environment variables
#
# Copy to `.env` (or `.env.local`) and adjust as needed. All values are optional;
# the defaults work for the standard "gateway serves web/dist on the same origin"
# deployment, where the app talks to the gateway over a relative `/ws` URL.

# Gateway WebSocket URL used by the Vite DEV server proxy (bun run web:dev).
# The dev server proxies /ws, /auth, and /api to this target. In production the
# gateway serves the built app and the proxy is not used.
#   Local gateway:            ws://localhost:4242   (default)
#   Remote/hosted gateway:    wss://demo.example.com
VITE_GATEWAY_URL=ws://localhost:4242
