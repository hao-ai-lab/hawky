{
  "name": "hawky",
  "version": "0.1.0",
  "type": "module",
  "description": "A personal assistant built on a powerful coding agent core",
  "main": "dist/index.js",
  "bin": {
    "hawky": "dist/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "skill-templates/",
    "web-dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "hawky": "bun run src/index.ts",
    "dev": "bun run src/index.ts",
    "gateway": "bun run src/index.ts gateway",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build && cp -r src/templates templates && cp -r src/skill-templates skill-templates && (cd web && bun install --frozen-lockfile && bun run build) && cp -r web/dist web-dist",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test ./tests/test-*.ts ./tests/test-*.tsx",
    "test:integration": "bun test ./tests/integration/*.ts",
    "test:e2e": "bun test --timeout 30000 --max-concurrency=1 ./tests/e2e-*.ts",
    "test:all": "bun test ./tests/test-*.ts ./tests/test-*.tsx && bun test ./tests/integration/*.ts && bun test --timeout 30000 --max-concurrency=1 ./tests/e2e-*.ts",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun run build",
    "web:test": "cd web && bun run test",
    "ios:generate": "cd ios && bash ./scripts/xcode-generate.sh",
    "ios:check-generated": "cd ios && bash ./scripts/xcode-check-generated.sh",
    "ios:build-sim": "cd ios && bash ./scripts/xcode-build.sh",
    "ios:install-device": "cd ios && ./scripts/ios-install.sh",
    "ios:test": "cd ios && bash ./scripts/xcode-test.sh unit",
    "ios:test:live": "cd ios && bash ./scripts/xcode-test-live.sh handshake",
    "ios:test:live:chat": "cd ios && bash ./scripts/xcode-test-live.sh chat",
    "ios:ui-test": "cd ios && bash ./scripts/xcode-test.sh ui",
    "ios:test:report": "cd ios && bash ./scripts/xcode-test-report.sh ui",
    "ios:sim-smoke": "cd ios && ./scripts/sim-smoke.sh",
    "ios:mcp:doctor": "npx -y -p xcodebuildmcp@2.6.2 xcodebuildmcp-doctor"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@slack/bolt": "^4.7.0",
    "canvas": "^3.2.0",
    "chalk": "^5.6.2",
    "chart.js": "^4.4.0",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "cli-table3": "^0.6.5",
    "croner": "^10.0.1",
    "diff": "^8.0.4",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "linkedom": "^0.18.12",
    "marked": "^17.0.4",
    "node-notifier": "^10.0.1",
    "openai": "^6.35.0",
    "pdf-parse": "1.1.1",
    "pinyin-pro": "^3.28.1",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/diff": "^8.0.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
