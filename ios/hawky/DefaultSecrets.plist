<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Local-only onboarding prefill template. Tracked so the project's
  "Copy Bundle Resources" build phase always finds the file (a clean clone /
  CI builds without errors), but the committed copy is EMPTY — no secrets.

  To prefill onboarding's Default connection on your own device, fill in the
  values below locally, then tell git to ignore your local edit so the secret
  is never committed:

      git update-index --skip-worktree ios/hawky/DefaultSecrets.plist

  When empty, onboarding's Default mode simply starts with blank Cloudflare
  Access fields and the user enters their own.
-->
<plist version="1.0">
<dict>
    <key>CloudflareAccessClientId</key>
    <string></string>
    <key>CloudflareAccessClientSecret</key>
    <string></string>
</dict>
</plist>
